VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_GOOGLE_CALENDAR_ENABLED=false
# Sprint A3 — pilot DecisionEngine contract (default false = legacy authority)
VITE_USE_NEW_DECISION_ENGINE=false
# Sprint A4 — OutcomeObservationEngine pilot (default false = no observation)
VITE_ENABLE_OUTCOME_OBSERVATION=false
# Sprint P1 — proactive study recommendation card (default false)
VITE_P1_STUDY_RECOMMENDATION=false
# Sprint P2 — smart study rescheduling (default false)
VITE_P2_SMART_RESCHEDULING=false
# EPIC1-A — Daily Brief (default false)
VITE_DAILY_BRIEF=false
# EPIC1-B — Explainable AI (default false)
VITE_EXPLAINABLE_AI=false
# EPIC1-C — Adaptive Daily Brief (default false)
VITE_DYNAMIC_DAILY_BRIEF=false
# EPIC2-A — User goals MVP (default false)
VITE_GOALS=false
# EPIC2-B — Goal progress assistant (default false)
VITE_GOAL_PROGRESS_ASSISTANT=false
# EPIC3-A — Household overview (default false)
VITE_HOUSEHOLD_OVERVIEW=false
# EPIC3-B — Household opportunities (default false)
VITE_HOUSEHOLD_OPPORTUNITIES=false
# EPIC3-C — Household collaboration proposals (default false)
VITE_HOUSEHOLD_COLLABORATION=false
# Production Netlify : https://equilibre-ia.netlify.app (sans slash final)
VITE_APP_ORIGIN=

# Playwright E2E (compte de test dédié — ne pas commiter)
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:5173

# QA-1 Quality Guardian (optionnel — voir Docs/QUALITY_GUARDIAN.md)
# GUARDIAN_TEST_PASSWORD=GuardianTest2026!
# GUARDIAN_VISUAL=1
# QA-2 optional — multi-member household provisioning (never commit)
# GUARDIAN_SUPABASE_SERVICE_ROLE_KEY=

# Migration Supabase (local uniquement — ne pas commiter)
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
