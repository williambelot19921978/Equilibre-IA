{
  "name": "equilibre-ia",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-vite-port.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test && playwright test --config playwright.guardian.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:production": "node scripts/playwright-production.mjs",
    "test:e2e:report": "playwright show-report reports",
    "test:e2e:epic4b": "playwright test --config playwright.epic4b.config.ts",
    "test:action-engine": "vitest run src/ai/actionEngine src/ai/conversationFoundation/conversation/actionEngineIntegration.test.ts src/components/assistant/AssistantActionCard.test.tsx",
    "test:planning-calendar-engine": "vitest run src/planningCalendarEngine",
    "test:calendar-sync-engine": "vitest run src/calendarSyncEngine",
    "test:semantic-planning-engine": "vitest run src/semanticPlanningEngine",
    "test:adaptive-intelligence-engine": "vitest run src/adaptiveIntelligenceEngine",
    "test:proactive-intelligence-engine": "vitest run src/proactiveIntelligenceEngine",
    "test:daily-state-engine": "vitest run src/dailyStateEngine",
    "test:personal-coach-engine": "vitest run src/personalCoachEngine",
    "test:life-knowledge-engine": "vitest run src/lifeKnowledgeEngine",
    "test:product-polish": "vitest run src/demo src/lib/onboarding src/lib/preferences/dailyCheckinPreference.test.ts src/lib/navigation/navigationEngine.test.ts",
    "test:mobile-reliability": "vitest run src/mobileReliability",
    "test:aura-design-system": "vitest run src/design-system/aura",
    "test:trust-center": "vitest run src/trustCenter",
    "test:aura-insights": "vitest run src/auraInsights",
    "test:release": "vitest run src/release",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "test:e2e:epic4c": "playwright test --config playwright.epic4c.config.ts",
    "test:human-model": "vitest run src/ai/humanModelFoundation src/ai/conversationFoundation/conversation/humanModelIntegration.test.ts src/ai/conversationFoundation/conversation/antiRecalcGuard.test.ts",
    "preview": "vite preview",
    "diagnose:calendar-checks": "node scripts/diagnose-calendar-checks.mjs",
    "verify:schema": "node scripts/verify-schema.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:contracts": "node scripts/verify-contract-boundaries.mjs",
    "verify:outcome": "vitest run src/ai/engines/outcome/outcomeObservationEngine.test.ts src/ai/outcome/outcomeObservationBridge.test.ts",
    "verify:p1": "vitest run src/lib/recommendations/buildStudySlotRecommendation.test.ts",
    "verify:p2": "vitest run src/lib/rescheduling/buildStudyRescheduleProposal.test.ts",
    "verify:dailybrief": "vitest run src/lib/dailyBrief/buildDailyBrief.test.ts",
    "verify:explainable": "vitest run src/lib/explainability/explainability.test.ts",
    "verify:dynamic-dailybrief": "vitest run src/lib/dailyBrief/refreshAdaptiveDailyBrief.test.ts",
    "verify:goals": "vitest run src/lib/goals/goals.test.ts",
    "verify:goal-progress": "vitest run src/lib/goals/goalProgressAssistant.test.ts",
    "verify:household-overview": "vitest run src/lib/householdOverview/householdOverview.test.ts",
    "verify:household-opportunities": "vitest run src/lib/householdOpportunities/householdOpportunities.test.ts",
    "verify:household-collaboration": "vitest run src/lib/householdCollaboration/householdCollaboration.test.ts",
    "quality-guardian": "node scripts/quality-guardian.mjs",
    "quality-guardian:headed": "node scripts/quality-guardian.mjs --headed",
    "quality-guardian:debug": "node scripts/quality-guardian.mjs --debug",
    "quality-guardian:report": "node scripts/quality-guardian.mjs --report-only",
    "release-check": "node scripts/release-check.mjs",
    "release-check:full": "node scripts/release-check.mjs --with-guardian",
    "quality-guardian:clean": "node scripts/guardian-clean.mjs",
    "probe:user-home-preferences": "node scripts/probe-user-home-preferences.mjs",
    "apply:repair-user-home-preferences": "node scripts/apply-user-home-preferences-repair.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.71.0",
    "postgres": "^3.4.7",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
